{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Backup Configuration Schema",
    "type": "object",
    "required": ["sources", "destination"],
    "properties": {
        "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["path"],
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "Source directory path"
                    },
                    "recursive": {
                        "type": "boolean",
                        "default": true,
                        "description": "Scan subdirectories"
                    },
                    "include": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Wildcard patterns to include (e.g., *.log)"
                    },
                    "exclude": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Wildcard patterns to exclude (e.g., *.tmp)"
                    }
                }
            }
        },
        "destination": {
            "type": "object",
            "required": ["path"],
            "properties": {
                "path": {
                    "type": "string",
                    "description": "Destination base path"
                },
                "timestampedFolder": {
                    "type": "boolean",
                    "default": true,
                    "description": "Create timestamped subdirectories"
                }
            }
        },
        "retention": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "default": false
                },
                "days": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Delete backups older than this many days"
                }
            }
        }
    },
    "example": {
        "sources": [
            {
                "path": "C:\\Windows\\System32\\winevt\\Logs",
                "recursive": true,
                "include": ["*.evtx"],
                "exclude": []
            }
        ],
        "destination": {
            "path": "D:\\Backups\\SecurityLogs",
            "timestampedFolder": true
        },
        "retention": {
            "enabled": true,
            "days": 90
        }
    }
}